{
    "name": "estudante/ci-cd-php",
    "description": "Projeto para estudar CI/CD com PHP",
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^1",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
